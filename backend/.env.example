# Server
PORT=5000

# MySQL connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=stadium_ticket_system

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=8h

# Seat lock duration, in minutes, while a fan is on the payment step
SEAT_LOCK_MINUTES=10
